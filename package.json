{
  "name": "story-architect-2",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n BACKEND,FRONTEND -c cyan,magenta \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:backend": "tsx watch backend/index.ts",
    "dev:frontend": "vite",
    "typecheck": "tsc --noEmit",
    "build": "vite build",
    "preview": "vite preview",
    "remote": "vite build && tsx backend/index.ts",
    "remote:backend": "tsx backend/index.ts",
    "test": "vitest run --config vitest.config.ts",
    "pipeline": "tsx scripts/pipeline-runner.ts",
    "pipeline:hook": "tsx scripts/pipeline-runner.ts --only hook",
    "pipeline:quick": "tsx scripts/pipeline-runner.ts --through character --turns 2 --skip-images",
    "pipeline:resume": "tsx scripts/pipeline-runner.ts --resume"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.57.0",
    "@tavily/core": "^0.7.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.2",
    "express": "^5.1.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vite": "^7.1.3",
    "vitest": "^4.1.0"
  }
}
